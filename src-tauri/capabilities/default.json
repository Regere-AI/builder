{
  "identifier": "main-capability",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "core:webview:allow-internal-toggle-devtools",
    "process:default",
    "fs:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "opener:default"
  ]
}