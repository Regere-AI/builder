{
  "name": "Builder",
  "version": "1.0.0",
  "description": "Regere Builder",
  "type": "module",
  "scripts": {
    "postinstall": "npm install --prefix backend && npm install --prefix shared",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "backend:start": "cd backend && npm run start",
    "tauri:dev": "concurrently \"npm run backend:start\" \"tauri dev\"",
    "tauri:dev:frontend": "tauri dev",
    "tauri:build": "tauri build",
    "build:mac": "node -e \"if(process.platform!=='darwin'){console.error('Build for macOS must be run on macOS');process.exit(1)}\" && tauri build",
    "build:win": "node -e \"if(process.platform!=='win32'){console.error('Build for Windows must be run on Windows');process.exit(1)}\" && tauri build"
  },
  "keywords": [
    "tauri",
    "react",
    "typescript",
    "vite"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.1.2",
    "@tauri-apps/cli": "^2",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.24",
    "postcss": "^8.5.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vite-plugin-monaco-editor": "^1.1.0"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-process": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "lucide-react": "^0.563.0",
    "monaco-editor": "^0.45.0",
    "react-arborist": "^3.4.3",
    "tailwind-merge": "^3.4.0"
  }
}
